const express = require('express');
const axios = require('axios');
const { v4: uuidv4 } = require('uuid');

const app = express();
const PORT = 3000;

// 🧠 Cache simples em memória
const cache = new Map();
const TTL = 60 * 1000; // 60s

// 🔁 Retry com backoff
async function fetchWithRetry(url, retries = 3) {
  for (let i = 0; i < retries; i++) {
    try {
      return await axios.get(url, { timeout: 2000 });
    } catch (err) {
      if (i === retries - 1) throw err;
      await new Promise(res => setTimeout(res, 200 * (i + 1)));
    }
  }
}

// 🧾 Middleware de correlation ID + logs JSON
app.use((req, res, next) => {
  const correlationId = req.headers['x-correlation-id'] || uuidv4();
  req.correlationId = correlationId;
  res.setHeader('x-correlation-id', correlationId);

  const start = Date.now();

  res.on('finish', () => {
    const log = {
      timestamp: new Date().toISOString(),
      level: 'info',
      correlation_id: correlationId,
      method: req.method,
      path: req.originalUrl,
      status_code: res.statusCode,
      duration_ms: Date.now() - start
    };

    console.log(JSON.stringify(log));
  });

  next();
});

// ❤️ Health check
app.get('/health', (req, res) => {
  res.status(200).json({
    status: 'ok',
    correlation_id: req.correlationId
  });
});

// 🔮 Endpoint principal
app.get('/wizard/:name', async (req, res) => {
  const name = req.params.name.toLowerCase();

  // 🔍 Verifica cache
  const cached = cache.get(name);
  if (cached && (Date.now() - cached.timestamp < TTL)) {
    return res.json({
      ...cached.data,
      source: 'cache',
      correlation_id: req.correlationId
    });
  }

  try {
    const response = await fetchWithRetry(
      'https://hp-api.onrender.com/api/characters'
    );

    const character = response.data.find(
      c => c.name && c.name.toLowerCase() === name
    );

    if (!character) {
      return res.status(404).json({
        error: 'Wizard not found',
        correlation_id: req.correlationId
      });
    }

    // 💾 salva cache
    cache.set(name, {
      data: character,
      timestamp: Date.now()
    });

    return res.json({
      ...character,
      source: 'api',
      correlation_id: req.correlationId
    });

  } catch (error) {
    console.error(JSON.stringify({
      timestamp: new Date().toISOString(),
      level: 'error',
      correlation_id: req.correlationId,
      message: 'Failed to fetch external API',
      error: error.message,
      path: req.originalUrl
    }));

    return res.status(500).json({
      error: 'Internal server error',
      correlation_id: req.correlationId
    });
  }
});

// 🚀 Start
app.listen(PORT, () => {
  console.log(JSON.stringify({
    timestamp: new Date().toISOString(),
    level: 'info',
    message: `Server running on port ${PORT}`
  }));
});
