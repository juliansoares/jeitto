{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "title": "RPS (Requests per Second)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total{status_code=~\"5..\"}[1m]) / rate(http_requests_total[1m])",
          "legendFormat": "error_rate"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Latency p95 (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[1m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(cache_hits_total[1m])",
          "legendFormat": "hits"
        },
        {
          "expr": "rate(cache_misses_total[1m])",
          "legendFormat": "misses"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "title": "External API Calls",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(external_api_calls_total[1m])",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },
    {
      "title": "External API Errors",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(external_api_errors_total[1m])",
          "legendFormat": "errors"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    }
  ],
  "schemaVersion": 30,
  "title": "SRE Arena Dashboard",
  "version": 1
}
